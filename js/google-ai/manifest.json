{
  "manifest_version": 3,
  "name": "No-AI Extension",
  "version": "1.0",
  "description": "Navigate to google without AI extension",
  "permissions": ["activeTab", "tabs", "webNavigation"],
  "background": {
      "service_worker": "background.js"
  },
  "content_scripts": [
    { 
      "js": ["content.js"],
      "matches": [
          "*://www.google.com/*"
      ]
    }
  ]
}
